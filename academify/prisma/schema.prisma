// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  STUDENT
  LECTURER
  ADMIN
}

enum EventRole {
  GUEST
  HOST
}

enum SpaceRole {
  MEMBER
  MODERATOR
  OWNER
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum DMRestriction {
  ALL
  CONNECTIONS
  LECTURERS
  NONE
}

enum UserStatus {
  ACTIVE
  WARNED
  SUSPENDED
  BANNED
}

enum ModerationStatus {
  PENDING
  APPROVED
  FLAGGED
  BLOCKED
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum ActionType {
  DELETE_POST
  DELETE_COMMENT
  APPROVE_POST
  FLAG_POST
  WARN_USER
  SUSPEND_USER
  BAN_USER
  UNBAN_USER
}

// Models

model User {
  userId    String   @id @default(cuid()) @map("userID")
  email     String   @unique
  password  String
  username  String   @unique
  name      String
  role      UserRole @default(STUDENT)
  major     String?
  bio       String?  @db.Text
  avatarUrl String?
  location  String?
  website   String?
  createdAt DateTime @default(now())

  // -- Setup & Profile Attributes --
  profileSetupComplete Boolean  @default(false)
  academicLevel        String?
  skillTags            String[]
  portfolioLinks       String[]

  // Lecturer Attributes
  department           String?
  specializations      String[]
  consultationHours    String?
  verifiedPublications String[]
  askMeAbout           String[]

  // -- Collaboration & Networking --
  activeProjects     String[]
  availabilityStatus AvailabilityStatus @default(AVAILABLE)

  // -- Privacy & Safety --
  showEmail         Boolean       @default(true)
  showAcademicLevel Boolean       @default(true)
  showLastSeen      Boolean       @default(true)
  dmRestriction     DMRestriction @default(ALL)

  // -- Admin Controls --
  accountStatus  UserStatus @default(ACTIVE)
  isShadowBanned Boolean    @default(false)

  // Relations
  posts              Post[]                @relation("UserPosts")
  comments           Comment[]             @relation("UserComments")
  files              File[]                @relation("UserFiles")
  createdEvents      Event[]               @relation("EventCreator")
  attendingEvents    EventAttendee[]       @relation("EventAttendees")
  sentMessages       Message[]             @relation("MessageSender")
  receivedMessages   Message[]             @relation("MessageReceiver")
  reportsMade        ReportReview[]        @relation("Reporter")
  reportsAgainstUser ReportReview[]        @relation("ReportedUser")
  moderationActions  ModerationActionLog[] @relation("ModeratorActions")
  followers          Follow[]              @relation("Follower")
  following          Follow[]              @relation("Following")
  moderatedForums    ForumModerator[]      @relation("ForumModerators")
  collabSpaces       SpaceMember[]         @relation("SpaceMembers")

  @@map("User")
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Following", fields: [followerId], references: [userId], onDelete: Cascade)
  following User @relation("Follower", fields: [followingId], references: [userId], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("Follow")
}

model ForumHub {
  forumID     String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  posts        Post[]
  moderators   ForumModerator[]
  events       Event[]
  collabSpaces CollabSpace[]

  @@map("ForumHub")
}

model ForumModerator {
  forumID String
  userID  String

  forum ForumHub @relation(fields: [forumID], references: [forumID], onDelete: Cascade)
  user  User     @relation("ForumModerators", fields: [userID], references: [userId], onDelete: Cascade)

  @@id([forumID, userID])
  @@map("ForumModerator")
}

model CollabSpace {
  spaceID     String   @id @default(cuid())
  forumID     String
  name        String
  description String?  @db.Text
  createdAt   DateTime @default(now())

  // Relations
  forum   ForumHub      @relation(fields: [forumID], references: [forumID], onDelete: Cascade)
  members SpaceMember[]
  files   File[]
  messages Message[]

  @@index([forumID])
  @@map("CollabSpace")
}

model SpaceMember {
  spaceID  String
  userID   String
  role     SpaceRole @default(MEMBER)
  joinedAt DateTime  @default(now())

  space CollabSpace @relation(fields: [spaceID], references: [spaceID], onDelete: Cascade)
  user  User        @relation("SpaceMembers", fields: [userID], references: [userId], onDelete: Cascade)

  @@id([spaceID, userID])
  @@index([userID])
  @@map("SpaceMember")
}

model Post {
  postID           String           @id @default(cuid())
  authorID         String
  forumID          String
  title            String
  content          String           @db.Text
  moderationStatus ModerationStatus @default(PENDING)
  aiScore          Float?
  aiLabel          String?
  aiReason         String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  author            User                  @relation("UserPosts", fields: [authorID], references: [userId], onDelete: Cascade)
  forum             ForumHub              @relation(fields: [forumID], references: [forumID], onDelete: Restrict)
  comments          Comment[]             @relation("PostComments")
  file              File?                 @relation("PostFile")
  reports           ReportReview[]        @relation("ReportedPost")
  moderationActions ModerationActionLog[] @relation("TargetPost")

  @@index([authorID])
  @@index([forumID])
  @@index([createdAt])
  @@map("Post")
}

model Comment {
  commentID String   @id @default(cuid())
  postID    String
  authorID  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  // Relations
  post              Post                  @relation("PostComments", fields: [postID], references: [postID], onDelete: Cascade)
  author            User                  @relation("UserComments", fields: [authorID], references: [userId], onDelete: Cascade)
  reports           ReportReview[]        @relation("ReportedComment")
  moderationActions ModerationActionLog[] @relation("TargetComment")

  @@index([postID])
  @@index([authorID])
  @@map("Comment")
}

model Event {
  eventID     String   @id @default(cuid())
  creatorID   String
  forumID     String
  title       String
  description String   @db.Text
  dateTime    DateTime
  location    String
  createdAt   DateTime @default(now())

  // Relations
  creator   User            @relation("EventCreator", fields: [creatorID], references: [userId], onDelete: Cascade)
  forum     ForumHub        @relation(fields: [forumID], references: [forumID], onDelete: Cascade)
  attendees EventAttendee[] @relation("EventAttendees")

  @@index([creatorID])
  @@index([forumID])
  @@index([dateTime])
  @@map("Event")
}

model EventAttendee {
  eventID String
  userID  String
  role    EventRole @default(GUEST)

  // Relations
  event Event @relation("EventAttendees", fields: [eventID], references: [eventID], onDelete: Cascade)
  user  User  @relation("EventAttendees", fields: [userID], references: [userId], onDelete: Cascade)

  @@id([eventID, userID])
  @@map("EventAttendee")
}

model File {
  fileID       String   @id @default(cuid())
  postID       String?  @unique
  uploadedByID String
  fileName     String
  fileUrl      String
  fileType     String
  fileSize     Int
  updatedAt    DateTime @updatedAt

  // Relations
  post       Post?        @relation("PostFile", fields: [postID], references: [postID], onDelete: Cascade)
  uploadedBy User         @relation("UserFiles", fields: [uploadedByID], references: [userId], onDelete: Cascade)
  spaceID    String?
  space      CollabSpace? @relation(fields: [spaceID], references: [spaceID], onDelete: Cascade)

  @@index([uploadedByID])
  @@index([spaceID])
  @@map("File")
}

model Message {
  messageID  String   @id @default(cuid())
  senderID   String
  receiverID String
  content    String   @db.Text
  read       Boolean  @default(false)
  sentAt     DateTime @default(now())
  spaceID    String?

  // Relations
  sender   User @relation("MessageSender", fields: [senderID], references: [userId], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverID], references: [userId], onDelete: Cascade)
  space    CollabSpace? @relation(fields: [spaceID], references: [spaceID], onDelete: Cascade)

  @@index([senderID])
  @@index([receiverID])
  @@index([sentAt])
  @@index([spaceID])
  @@map("Message")
}

model ReportReview {
  reportreviewID    String       @id @default(cuid())
  reporterID        String
  reportedUserID    String?
  reportedPostID    String?
  reportedCommentID String?
  reason            String
  description       String       @db.Text
  status            ReportStatus @default(PENDING)
  reviewedAt        DateTime?
  createdAt         DateTime     @default(now())

  // Relations
  reporter          User                  @relation("Reporter", fields: [reporterID], references: [userId], onDelete: Cascade)
  reportedUser      User?                 @relation("ReportedUser", fields: [reportedUserID], references: [userId], onDelete: Cascade)
  reportedPost      Post?                 @relation("ReportedPost", fields: [reportedPostID], references: [postID], onDelete: Cascade)
  reportedComment   Comment?              @relation("ReportedComment", fields: [reportedCommentID], references: [commentID], onDelete: Cascade)
  moderationActions ModerationActionLog[] @relation("RelatedReport")

  @@index([reporterID])
  @@index([status])
  @@map("ReportReview")
}

model ModerationActionLog {
  ModaiID         String     @id @default(cuid())
  modID           String
  targetUserID    String?
  targetPostID    String?
  targetCommentID String?
  relatedReportID String?
  actionType      ActionType
  reason          String     @db.Text
  details         String?    @db.Text
  duration        Int?
  timestamp       DateTime   @default(now())

  // Relations
  moderator     User          @relation("ModeratorActions", fields: [modID], references: [userId], onDelete: Cascade)
  targetPost    Post?         @relation("TargetPost", fields: [targetPostID], references: [postID], onDelete: SetNull)
  targetComment Comment?      @relation("TargetComment", fields: [targetCommentID], references: [commentID], onDelete: SetNull)
  relatedReport ReportReview? @relation("RelatedReport", fields: [relatedReportID], references: [reportreviewID], onDelete: SetNull)

  @@index([modID])
  @@index([timestamp])
  @@map("ModerationActionLog")
}

model AuthUser {
  id            String        @id
  name          String
  email         String
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  authsessions  AuthSession[]
  authaccounts  AuthAccount[]

  @@unique([email])
  @@map("AuthUser")
}

model AuthSession {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  authuser  AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("AuthSession")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  authuser              AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("AuthAccount")
}

model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("AuthVerification")
}
