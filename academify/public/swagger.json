{
  "openapi": "3.0.0",
  "info": {
    "title": "Academify API",
    "description": "API documentation for Academify",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Register new user"
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Login user"
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Logout"
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Get current user"
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Refresh token"
      }
    },
    "/api/users/{userId}": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get user profile"
      },
      "put": {
        "tags": [
          "Users"
        ],
        "summary": "Update user profile"
      },
      "delete": {
        "tags": [
          "Users"
        ],
        "summary": "Delete account"
      }
    },
    "/api/users/{userId}/posts": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get user's posts"
      }
    },
    "/api/users/{userId}/events": {
      "get": {
        "tags": [
          "Users"
        ],
        "summary": "Get user's events"
      }
    },
    "/api/events": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "List events (filters: upstream, page)"
