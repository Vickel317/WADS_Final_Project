      "post": {
        "tags": [
          "Events"
        ],
        "summary": "Create new event"
      }
    },
    "/api/events/{eventId}": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Get event details with attendees"
      },
      "put": {
        "tags": [
          "Events"
        ],
        "summary": "Update own event"
      },
      "delete": {
        "tags": [
          "Events"
        ],
        "summary": "Delete own event"
      }
    },
    "/api/events/{eventId}/rsvp": {
      "post": {
        "tags": [
          "Events"
        ],
        "summary": "RSVP to event"
      },
      "delete": {
        "tags": [
          "Events"
        ],
        "summary": "Cancel RSVP"
      }
    },
    "/api/events/{eventId}/attendees": {
      "get": {
        "tags": [
          "Events"
        ],
        "summary": "Get attendee list"
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object"
      },
      "Event": {
        "type": "object"
      }
    }
  }
